<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme"
        app:title="@string/Graph_header"
        app:titleTextAppearance="?attr/textAppearanceHeadlineSmall" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <!-- Time Period Selector Chips -->
            <com.google.android.material.chip.ChipGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                app:chipSpacing="8dp"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_1m"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/month_1"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_3m"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/month_3"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_6m"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/month_6"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_1y"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/year_1"
                    android:checkable="true" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Spent per Category Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/spendingPerCategoryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Card Title -->
                    <TextView
                        android:id="@+id/textSpendingTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/spending_per_cat"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textStyle="bold"
                        android:textColor="@color/text_muted_light"
                        android:layout_marginBottom="16dp" />

                    <!-- Message when no categories exist -->
                    <TextView
                        android:id="@+id/textNoCategories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No categories found. Add categories to see spending breakdown."
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/text_muted_light"
                        android:visibility="gone"
                        android:padding="16dp" />

                    <!-- Dynamic Container for Category Rows -->
                    <LinearLayout
                        android:id="@+id/categoriesContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Goal Indicators Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Card Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/colour_key"
                        android:textColor="@color/text_muted_light"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- Actual Spend -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="24dp"
                            android:layout_height="8dp"
                            android:layout_marginEnd="12dp"
                            android:background="@color/accent_purple_light" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/colour_key_spend"
                            android:textAppearance="?attr/textAppearanceBodyMedium" />
                    </LinearLayout>

                    <!-- Min Goal -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="5dp"
                            android:layout_height="22dp"
                            android:layout_marginEnd="12dp"
                            android:background="@color/accent_green_bright" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/colour_key_min_goal"
                            android:textAppearance="?attr/textAppearanceBodyMedium" />
                    </LinearLayout>

                    <!-- Max Goal -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="5dp"
                            android:layout_height="28dp"
                            android:layout_marginEnd="12dp"
                            android:background="@color/danger_dark" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/colour_key_max_goal"
                            android:textAppearance="?attr/textAppearanceBodyMedium" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>